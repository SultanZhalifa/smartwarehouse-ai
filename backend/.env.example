# Smart Warehouse — Environment Configuration
# Copy this file to .env and customize values

# Backend secret key (used for session token generation)
# IMPORTANT: Change this in production!
SECRET_KEY=smartwarehouse-dev-key-change-in-production

# SQLite database path (relative to backend/)
DB_PATH=warehouse.db

# Default detection confidence threshold (0-100)
DEFAULT_THRESHOLD=25

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Roboflow API key (only needed if you re-run download_datasets.py)
# Get yours at: https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=
